function ContactForm(){
  const [form, setForm] = useState({ adsoyad: "", email: "", tel: "", mesaj: "" });
  const [status, setStatus] = useState("");

  function onSubmit(e){
    e.preventDefault();
    // Basit doğrulama
    if(!form.adsoyad || !form.email || !form.mesaj){
      setStatus("Lütfen gerekli alanları doldurun.");
      return;
    }
    // Demo amaçlı, burada e-posta/HTTP isteği yapılabilir
    setStatus("Mesajınız alındı. En kısa sürede dönüş yapacağız.");
    setForm({ adsoyad: "", email: "", tel: "", mesaj: "" });
  }

  return (
    <form onSubmit={onSubmit} className="grid gap-3">
      <Input placeholder="Ad Soyad *" value={form.adsoyad} onChange={e=>setForm(f=>({...f,adsoyad:e.target.value}))} className="rounded-2xl"/>
      <Input type="email" placeholder="E‑posta *" value={form.email} onChange={e=>setForm(f=>({...f,email:e.target.value}))} className="rounded-2xl"/>
      <Input placeholder="Telefon" value={form.tel} onChange={e=>setForm(f=>({...f,tel:e.target.value}))} className="rounded-2xl"/>
      <Textarea placeholder="Mesaj *" value={form.mesaj} onChange={e=>setForm(f=>({...f,mesaj:e.target.value}))} className="rounded-2xl min-h-32"/>
      <div className="flex items-center justify-between">
        <small className="text-slate-500">* Zorunlu alan</small>
        <Button type="submit" className="rounded-2xl px-6" style={{background:PALETTE.navy}}>Gönder</Button>
      </div>
      {status && <div className="text-sm text-slate-600">{status}</div>}
    </form>
  );
}

